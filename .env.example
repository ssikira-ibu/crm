# Production deployment env template.
# Copy to .env on the server (chmod 600) and fill in values.
# Never commit the filled-in .env.

# --- PostgreSQL (generate password: openssl rand -base64 32) ---
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# --- Auth secrets (generate each: openssl rand -base64 32) ---
SESSION_SECRET=
S2S_JWT_SECRET=

# --- Firebase Admin SDK ---
# Paste the full service account JSON as a single line (use `jq -c . key.json`).
FIREBASE_SERVICE_ACCOUNT_JSON=

# --- Firebase client config (safe to expose to browser) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Cloudflare Tunnel ---
TUNNEL_TOKEN=

# --- Public domain (used for ALLOWED_ORIGINS on backend) ---
DOMAIN=
