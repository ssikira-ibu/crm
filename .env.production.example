# Domain (used by Caddy for TLS and CORS)
DOMAIN=crm.ssikira.com

# GHCR images (set by CI, or manually for first deploy)
IMAGE_PREFIX=ghcr.io/OWNER/REPO
IMAGE_TAG=latest

# PostgreSQL (generate with: openssl rand -base64 32)
POSTGRES_USER=crm
POSTGRES_PASSWORD=
POSTGRES_DB=crm

# Auth secrets (generate with: openssl rand -base64 32)
SESSION_SECRET=
S2S_JWT_SECRET=

# Firebase (client-side config — safe to expose, but keep out of git)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
